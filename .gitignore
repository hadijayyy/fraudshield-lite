# FraudShield-Lite — .gitignore

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# Logs
logs/
*.log

# Environment
.env
.env.*

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Notebook checkpoints
.ipynyn_checkpoints/

# Docker
.dockerignore

# Coverage
.coverage
htmlcov/
coverage.xml

# Data (regeneratable)
data/*.csv
data/*.zip
